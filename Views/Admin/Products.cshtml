@model IEnumerable<SimpleEcom.Models.Product>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary">Quản lý kho hàng</h2>
        @if (User.Identity.IsAuthenticated)
        {
            <a href="/admin/createproduct" class="btn btn-success rounded-pill shadow-sm"><i class="bi bi-plus-lg"></i> Thêm
                sản phẩm</a>
        }
    </div>

    <div class="card border-0 shadow-sm mb-4 bg-light">
        <div class="card-body">
            <form action="/admin/products" method="get" class="row g-3">
                <input type="hidden" name="category" value="@ViewBag.SelectedCategory" />
                <input type="hidden" name="query" value="@ViewBag.CurrentQuery" />

                <div class="col-md-6">
                    <div class="input-group shadow-sm">
                        <input type="search" name="query" class="form-control" placeholder="Tìm..."
                            value="@ViewBag.CurrentQuery" onclick="this.select()" />
                        <button class="btn btn-primary px-4 text-white" type="submit">
                            <i class="bi bi-search"></i>Tìm
                        </button>
                    </div>
                </div>
                <div class="d-flex align-items-center gap-3 mb-4 mt-3 p-3 bg-light rounded shadow-sm">
                    <span class="fw-bold text-secondary"><i class="bi bi-filter-left"></i>Sắp xếp theo:</span>
                    <a href="/admin/products?category=@ViewBag.SelectedCategory&query=@ViewBag.CurrentQuery&sortOrder="
                        class="btn btn-sm @(string.IsNullOrEmpty(ViewBag.CurrentSort) ? "btn-primary" : "btn-outline-secondary") rounded-pill px-3">Mặc
                        định</a>

                    <a href="/admin/products?category=@ViewBag.SelectedCategory&query=@ViewBag.CurrentQuery&sortOrder=price_asc"
                        class="btn btn-sm @((ViewBag.CurrentSort == "price_asc") ? "btn-primary" : "btn-outline-secondary") rounded-pill px-3"><i
                            class="bi bi-sort-numeric-down"></i>Giá ↑</a>

                    <a href="/admin/products?category=@ViewBag.SelectedCategory&query=@ViewBag.CurrentQuery&sortOrder=price_desc"
                        class="btn btn-sm @((ViewBag.CurrentSort == "price_desc") ? "btn-primary" : "btn-outline-secondary") rounded-pill px-3"><i
                            class="bi bi-sort-numeric-up-alt"></i>Giá ↓</a>
                </div>
            </form>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-12 d-flex justify-content-center gap-2">
            <a href="/admin/products?query=@ViewBag.CurrentQuery&sortOrder=@ViewBag.CurrentSort"
                class="btn @(string.IsNullOrEmpty(ViewBag.SelectedCategory) ? "btn-primary" : "btn-outline-primary") rounded-pill px-3">Tất
                cả</a>
            <a href="/admin/products?category=Điện tử&query=@ViewBag.CurrentQuery&sortOrder=@ViewBag.CurrentSort"
                class="btn @(ViewBag.SelectedCategory == "Điện tử" ? "btn-primary" : "btn-outline-primary") rounded-pill px-3">
                <i class="bi bi-cpu"></i> Điện tử
            </a>
            <a href="/admin/products?category=Gia dụng&query=@ViewBag.CurrentQuery&sortOrder=@ViewBag.CurrentSort"
                class="btn @(ViewBag.SelectedCategory == "Gia dụng" ? "btn-primary" : "btn-outline-primary") rounded-pill px-3">
                <i class="bi bi-house"></i> Gia dụng
            </a>
        </div>
    </div>
    <div class="card border-0 shadow-sm overflow-hidden">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th class="ps-4">Sản phẩm</th>
                    <th>Giá</th>
                    <th>Danh mục</th>
                    <th>Kho</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4">
                            <div class="d-flex align-items-center gap-3">
                                <img src="@item.ImageUrl" class="rounded-border" style = "width: 50px; height: 50px; object-fit: cover;" />
                                <div>
                                    <div class="fw-bold">@item.Name</div>
                                    <small class="text-muted">ID: #@item.Id</small>
                                </div>
                            </div>
                        </td>
                        <td class="fw-bold text-primary">@item.Price.ToString("N0") đ</td>
                        <td>
                            <span class="badge bg-info-subtle text-info px-3">@item.Category</span>
                        </td>
                        <td>
                            @if(item.Stock <= 5){
                                <span class="badge bg-danger">Sấp hết: @item.Stock</span>
                            }else{
                                <span class="badge bg-info">Còn lại: @item.Stock</span>
                            }
                        </td>
                        <td class="text-center">
                            <div class="btn-group">
                                @if(User.Identity.IsAuthenticated){
                                    <a href="/admin/edit/@item.Id" class="btn btn-outline-warning" title="Sửa"><i class="bi bi-pencil"></i>
                                    </a>
                                    <a href="/admin/delete/@item.Id" class="btn btn-outline-danger"
                                    onclick="return confirm('Xóa sản phẩm nầy?')" title="Xóa"><i class="bi bi-trash"></i>
                                    </a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="mt-4">
        <a href="/admin/orders" class="btn btn-link text-decoration-none text-secondary p-0">
            <i class="bi bi-arrow-left"></i> Quay lại trang đơn hàng
        </a>
    </div>
</div>