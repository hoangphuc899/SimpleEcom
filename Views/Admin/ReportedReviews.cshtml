@model IEnumerable<SimpleEcom.Models.ReportedReview>

<div class="container mt-4">
    <h3 class="mb-4">
        <i class="bi bi-exclamation-octagon text-danger"></i> Quản lý báo cáo bình luận
    </h3>
    @if(TempData["Success"] != null){
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss = "alert"></button>
        </div>
    }
    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th>Người gửi</th>
                        <th>Nội dung bình luận</th>
                        <th>Lý do báo cáo</th>
                        <th>Ngày báo</th>
                        <th class="text-end">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach(var item in Model.Where(r => !r.IsResolved)){
                        <tr>
                            <td>
                                <span class="fw-bold">@item.Review?.FullName</span>
                            </td>
                            <td style="max-width: 300px;">
                                <div class="text-truncate" title="@item.Review?.Comment">
                                    "@item.Review?.Comment"
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-danger bg-opacity-10 text-danger border border-danger">@item.Reason</span>
                            </td>
                            <td class="small text-muted">
                                @item.DateReported.ToString("dd/MM HH:mm")
                            </td>
                            <td class="text-end">
                                <div class="d-flex justify-content-end gap-2">
                                    <form asp-action="ResolveReport" method="post">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="deleteComment" value="false" />
                                        <button type="submit" class="btn btn-sm btn-outline-secondary">
                                            <i class="bi bi-eye-slash"></i> Bỏ qua
                                        </button>
                                    </form>
                                    <form asp-action="ResolveReport" method="post">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="deleteComment" value="true" />
                                        <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Bạn có chắc chắn muốn XÓA VĨNH VIỄN bình luận này?')">
                                            <i class="bi bi-trash"></i> Xóa vi phạm
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>