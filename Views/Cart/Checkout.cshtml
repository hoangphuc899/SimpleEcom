@model SimpleEcom.Models.Order
@using Newtonsoft.Json
@inject ICartService CartService

@{
    ViewData["Title"] = "Thanh toán";
    var cart = CartService.GetCart();
    var subTotal = CartService.GetTotal();
    var discount = Model.DiscountAmount;
    var finalTotal = subTotal - discount;
}
<div class="container mt-5">
    <div class="row">
        <div class="col-md-7">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0"><i class="bi bi-person-bounding-box me-2"></i>Thông tin giao hàng</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="ProcessCheckout" method="post">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Họ tên khách hàng</label>
                            <input asp-for="CustomerName" class="form-control form-control-lg" placeholder="Ví dụ: Nguyễn Văn A" required />
                        </div>
                        <div class="row">
                            <div class="col-md-12 mb-3">
                                <label class="form-label fw-bold">Số điện thoại</label>
                                <input asp-for="Phone" class="form-control form-control-lg" placeholder="Nhập số điện thoại để liên hệ" required />
                            </div>
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-bold">Địa chỉ nhận hàng</label>
                            <textarea asp-for="Address" class="form-control" rows="3" placeholder="Số nhà, tên đường, phường/xã..." required></textarea>
                        </div>
                        <input type="hidden" asp-for="VoucherCode" />
                        <input type="hidden" asp-for="DiscountAmount" />
                        
                        <button type="submit" class="btn btn-success btn-lg w-100 py-3 fw-bold shadow-sm">
                            <i class="bi bi-cart-check-fill me-2"></i>Xác nhận đặt hàng
                        </button>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-md-5">
            <div class="card shadow-sm border-0 bg-light">
                <div class="card-header py-3">
                    <h5 class="mb-0">Tóm tắt đơn hàng</h5>
                </div>
                <div class="card-body">
                    <div class="list-group list-group-flush mb-3">
                        @foreach(var item in cart){
                            <div class="list-group-item bg-transparent d-flex justify-content-between align-items-center px-0">
                                <div>
                                    <h6 class="my-0">@item.ProductName</h6>
                                    <small class="text-muted">Số lượng: @item.Quantity</small>
                                </div>
                                <span class="text-muted">@((item.Price * item.Quantity).ToString("N0")) đ</span>
                            </div>
                        }
                    </div>
                    <div class="mb-4 text-success small fw-bold">
                        <i class="bi bi-calendar-check me-1"></i>
                        Dự kiến nhận hàng: 2 - 4 ngày.
                    </div>
                    <div class="border-top pt-3">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="h5">Tạm tính:</span>
                            <span class="h4 text-info fw-bold">
                                @subTotal.ToString("N0") đ
                            </span>
                        </div>
                        @if(discount > 0){
                        <div class="d-flex justify-content-between mb-2 text-danger">
                            <span>Giảm giá: (Voucher: @Model.VoucherCode):</span>
                            <span>- @discount.ToString("N0") đ</span>
                        </div>
                        }
                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <span class="h5">Tổng cộng:</span>
                            <span class="h4 text-info fw-bold">
                                @finalTotal.ToString("N0") đ
                            </span>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-white border-0 py-3">
                    <small class="text-muted">
                        <i class="bi bi-shield-lock me-1"></i> Thông tin của bạn được bảo mật tuyệt đối.
                    </small>
                </div>
            </div>
            <div class="mt-3">
                <a asp-controller="Cart" asp-action="Index" class="text-decoration-none text-muted"><i class="bi bi-arrow-left me-1"></i> Quay lại giỏ hàng</a>
            </div>
        </div>
    </div>
</div>