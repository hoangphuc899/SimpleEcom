@model SimpleEcom.Models.Order
@using Newtonsoft.Json

@{
    ViewData["Title"] = "Đặt hàng thành công!";
    // giải nén JSON từ DB ra để hiển thị danh sách món hàng
    var items = JsonConvert.DeserializeObject<List<CartItem>>(Model.OrderItemsJson);
}
<div class="container mt-5 text-center">
    <div class="card shadow p-4">
        <div class="card-body">
            <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
            <h2 class="mt-3">Cảm ơn bạn đã đặt hàng!</h2>
            <p class="text-muted">Mã đơn hàng của bạn là: <strong>#@Model.Id</strong></p>
            <hr />
            <div class="text-start mt-4">
                <h5>Thông tin nhận hàng:</h5>
                <p><strong>Người nhận:</strong> @Model.CustomerName</p>
                <p><strong>Số điện thoại:</strong> @Model.Phone</p>
                <p><strong>Địa chỉ:</strong> @Model.Address</p>
            </div>
            <table class="table table-bordered mt-4">
                <thead class="table-light">
                    <tr>
                        <th>Sản phẩm</th>
                        <th>Số lượng</th>
                        <th>Đơn giá</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach(var item in items){
                        <tr>
                            <td>@item.ProductName</td>
                            <td>@item.Quantity</td>
                            <td>@item.Price.ToString("N0") đ</td>
                        </tr>
                    }
                </tbody>
            </table>
            <h4 class="text-info mt-3 text-end">Tổng tiền: @Model.TotalAmount.ToString("N0") đ</h4>
            <div class="mt-5">
                <a asp-controller="Product" asp-action="Index" class="btn btn-primary btn-lg px-5 shadow-sm">Tiếp tục mua sắm</a>
            </div>
        </div>
    </div>
</div>