@model SimpleEcom.Models.Order

<div class="container mt-5">
    <div class="card shadow-sm border-0">
        <div class="card-body text-center p-5">
            <div class="mb-4">
                <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
            </div>
            <h2 class="fw-bold">Đặt hàng thành công!</h2>
            <p class="text-muted">Mã đơn hàng của bạn là: <strong>#@Model.Id</strong></p>
            <hr />
            <div class="row justify-content-center my-4">
                <div class="col-md-5 text-center mb-4">
                    <h5>Quét mã để thanh toán</h5>
                    <img src="https://img.vietqr.io/image/ACB-22016617-qr_only.png?amount=@Model.TotalAmount&addInfo=THANH TOAN DON HANG @Model.Id" class="img-fluid shadow rounded" alt="QR Thanh toán" style="max-width: 250px;" />
                    <p class="small text-muted mt-2">Sử dụng ứng dụng Ngân hàng hoặc Ví điện tử để quét</p>
                </div>
                <div class="col-md-6 text-start">
                    <h5><i class="bi bi-info-circle"></i> Thông tin chuyển khoản</h5>
                    <div class="bg-light p-3 rounded">
                        <p><strong>Tổng tiền:</strong>
                            <span class="text-success fs-5">
                                @Model.TotalAmount.ToString("N0") đ
                            </span>
                        </p>
                        <p><strong>Ngân hàng: </strong>ACB</p>
                        <p><strong>Số tài khoản: </strong>22016617</p>
                        <p><strong>Chủ tài khoản: </strong>NGUYỄN HOÀNG PHÚC</p>
                        <p><strong>Nội dung: </strong>
                            <span class="text-primary fw-bold">Thanh toán đơn hàng #@Model.Id</span>
                        </p>
                    </div>
                </div>
            </div>
            <div class="mt-4 text-center">
                <p class="text-danger"><i>* Sau khi chuyển khoản vui lòng bấm nút dưới đây để xác nhận.</i></p>
                <form asp-action="ConfirmPayment" method="post">
                    <input type="hidden" name="orderId" value="@Model.Id" />
                    <a href="/" class="btn btn-outline-secondary px-4"> Quay lại</a>
                    <button type="submit" class="btn btn-success px-5 fw-bold">
                        <i class="bi bi-cash-coin"></i> Đã thanh toán
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>