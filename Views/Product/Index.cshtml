@model IEnumerable<SimpleEcom.Models.Product>

<div class="container mt-4">
    <h2 class="mb-4">Danh sách sản phẩm</h2>

    <div class="row mb-4">
        <div class="col-md-6 mx-auto">
            <form action="/Product/Index" method="get">
                <input type="hidden" name="category" value="@ViewBag.SelectedCategory" />

                <div class="input-group shadow-sm">
                    <input type="search" name="query" class="form-control rounded-pill-start border-end-0"
                        placeholder="Tìm kiếm..." value="@ViewBag.CurrentQuery" onclick="this.select()" />
                    <button type="submit" class="btn btn-primary rounded-pill-end px-4 text-white">
                        <i class="bi bi-search"></i> Tìm
                    </button>
                </div>
            </form>
        </div>
    </div>
    <div class="d-flex justify-content-center gap-2 mb-4">
        <a href="/product/index?query=@ViewBag.CurrentQuery&sortOrder=@ViewBag.CurrentSort"
            class="btn @(string.IsNullOrEmpty(ViewBag.SelectedCategory) ? "btn-primary" : "btn-outline-primary") rounded-pill px-3">
            Tất cả
        </a>
        <a href="/product/index?category=Điện tử&query=@ViewBag.CurrentQuery&sortOrder=@ViewBag.CurrentSort"
            class="btn @(ViewBag.SelectedCategory == "Điện tử" ? "btn-primary" : "btn-outline-primary") rounded-pill px-3">
            <i class="bi bi-cpu"></i> Điện tử
        </a>
        <a href="/product/index?category=Gia dụng&query=@ViewBag.CurrentQuery&sortOrder=@ViewBag.CurrentSort"
            class="btn @(ViewBag.SelectedCategory == "Gia dụng" ? "btn-primary" : "btn-outline-primary") rounded-pill px-3">
            <i class="bi bi-house"></i> Gia dụng
        </a>
    </div>
    <div class="d-flex align-items-center justify-content-between mb-4 p-2 bg-light rounded-3 shadow-sm">
        <div class="d-flex gap-2">
            <span class="text-muted small align-self-center d-none d-md-block"><i class="bi bi-filter-left"></i>Sắp xếp
                theo:</span>
            <a href="/product/index?category=@ViewBag.SelectedCategory&query=@ViewBag.CurrentQuery&sortOrder="
                class="btn btn-sm @(string.IsNullOrEmpty(ViewBag.CurrentSort) ? "btn-primary" : "btn-outline-secondary") rounded-pill px-3">
                    Mặc định
            </a>

            <a href="/product/index?category=@ViewBag.SelectedCategory&query=@ViewBag.CurrentQuery&sortOrder=price_asc"
                class="btn btn-sm @((ViewBag.CurrentSort == "price_asc") ? "btn-primary" : "btn-outline-secondary") rounded-pill px-3">
                <i class="bi bi-sort-down"></i> Giá thấp - cao
            </a>

            <a href="/product/index?category=@ViewBag.SelectedCategory&query=@ViewBag.CurrentQuery&sortOrder=price_desc"
                class="btn btn-sm @((ViewBag.CurrentSort == "price_desc") ? "btn-primary" : "btn-outline-secondary") rounded-pill px-3">
                <i class="bi bi-sort-up-alt"></i> Giá cao - thấp
            </a>
        </div>
    </div>
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
        @foreach (var item in Model)
        {
            <div class="col-md-3 mb-4 d-flex align-items-stretch">
                <div class="card h-100 shadow-sm border-0 position-relative d-flex flex-column w-100">
                    <div style="height: 200px; overflow: hidden;" class="bg-light position-relative">
                        @if(ViewBag.Personalized != null && item.Category == ViewBag.FavoriteCategory)
                        {
                            <span class="badge bg-warning text-dark position-absolute m-2 shadow-sm" style="top: 0; left: 0; z-index: 10;">
                                <i class="bi bi-star-fill"></i> @ViewBag.Personalized
                            </span>
                        }
                        <div id="carousel-@item.Id" class="carousel slide carousel-fade h-100" data-bs-ride = "carousel" data-bs-interval = "3000">
                            <div class="carousel-inner h-100">
                                <div class="carousel-item active h-100">
                                    <a href="/product/details/@item.Id" class="position-relative">
                                        <img src="@item.ImageUrl" class="card-img-top d-block w-100 h-100" alt="@item.Name"
                                        style="height:200px; object-fit:cover;" />
                                        @if(item.Stock <= 0){
                                            <span class="position-absolute top-50 start-50 translate-middle badge bg-danger fs-6">HẾT HÀNG</span>
                                        }
                                    </a>   
                                </div>
                                @if(item.Images != null){
                                    foreach(var subImg in item.Images){
                                        <div class="carousel-item h-100">
                                            <img src="@subImg.Url" class="card-img-top d-block w-100 h-100" style="height: 200px; object-fit: cover;" />
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                    <div class="card-body d-flex flex-column text-center">
                        <h5 class="card-title" title="@item.Name">
                            <a asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none text-dark">
                                @item.Name
                            </a>
                        </h5>
                        <p class="card-text text-muted small flex-grow-1" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; min-height: 40px;">
                            @item.Description
                        </p>
                        <div class="mt-auto">
                            <div class="text-muted small">
                                <del>@((item.Price * 1.1m).ToString("N0")) đ</del>
                            </div>
                            <h5 class="text-primary fs-5 mb-2">
                                @item.Price.ToString("N0") đ
                            </h5>
                            @if(item.Stock > 0){
                                <a href="/product/details/@item.Id" class="btn btn-info btn-sm rounded-pill w-100 shadow-sm">
                                    <i class="bi bi-info-circle"></i> Chi tiết
                                </a>
                            }else{
                                <button class="btn btn-secondary btn-sm rounded-pill w-100" disabled>
                                    Chờ nhập hàng
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>