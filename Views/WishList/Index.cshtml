@model IEnumerable<SimpleEcom.Models.WishList>

<div class="container mt-4">
    <h3><i class="bi bi-heart-fill text-danger"></i> Sản phẩm bạn đã thích</h3>
    <div class="row mt-4">
        @foreach(var item in Model)
        {
            <div class="col-md-3 mb-3">
                <div class="card shadow-sm border-0">
                    <img src="@item.Product.ImageUrl" class="card-img-top" style="height: 200px; object-fit: cover;" />
                    <div class="card-body">
                        <h6>@item.Product.Name</h6>
                        <p class="text-primary fw-bold">@item.Product.Price.ToString("N0") đ</p>
                        <a href="/Product/Details/@item.ProductId" class="btn btn-sm btn-outline-primary w-100">Xem lại</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>